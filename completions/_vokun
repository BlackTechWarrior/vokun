#compdef vokun
# Zsh completion for vokun
# Place this file in a directory listed in $fpath (e.g. /usr/share/zsh/site-functions/)

_vokun_bundle_names() {
    local -a bundles
    bundles=( ${(f)"$(vokun list --names-only 2>/dev/null)"} )
    _describe -t bundles 'bundle' bundles
}

_vokun() {
    local -a subcommands
    subcommands=(
        'install:Install a bundle'
        'remove:Remove a bundle'
        'select:Change pick-one selections for a bundle'
        'list:List bundles'
        'info:Show bundle info'
        'search:Search for packages'
        'get:Get a package'
        'yeet:Remove a package'
        'find:Find a package'
        'which:Which bundle owns a package'
        'owns:Show package owner'
        'update:Update packages'
        'orphans:List orphaned packages'
        'cache:Manage package cache'
        'size:Show package sizes'
        'recent:Show recently installed'
        'foreign:List foreign packages'
        'explicit:List explicitly installed'
        'export:Export custom bundles and config'
        'import:Import bundles from a file'
        'broken:Check for broken symlinks and deps'
        'hook:Manage pacman notification hook'
        'setup:Check and install optional dependencies'
        'uninstall:Remove vokun from the system'
        'bundle:Manage custom bundles'
        'sync:Reconcile state with installed packages'
        'check:AUR trust scoring for a package'
        'diff:View PKGBUILD for an AUR package'
        'profile:Manage installation profiles'
        'log:Show action log'
        'rollback:Undo the last reversible action'
        'dotfiles:Manage dotfiles'
        'status:Show system overview and stats'
        'why:Show which bundles include a package'
        'snapshot:Save and restore system snapshots'
        'untracked:List ad-hoc packages not in any bundle'
        'history:Show pacman transaction history'
        'doctor:Run all health checks'
        'help:Show help'
    )

    _arguments -C \
        '(-y --yes)'{-y,--yes}'[Skip confirmation prompts]' \
        '--no-color[Disable colored output]' \
        '(-v --version)'{-v,--version}'[Show version]' \
        '1:subcommand:->subcmd' \
        '*::arg:->args'

    case "$state" in
        subcmd)
            _describe -t subcommands 'vokun subcommand' subcommands
            ;;
        args)
            case "${words[1]}" in
                install)
                    _arguments \
                        '--pick[Interactively select packages]' \
                        '--exclude[Skip specific packages]:packages:' \
                        '--only[Install only these packages]:packages:' \
                        '--dry-run[Preview without installing]' \
                        '*:bundle:_vokun_bundle_names'
                    ;;
                info)
                    _vokun_bundle_names
                    ;;
                remove)
                    _arguments \
                        '--dry-run[Preview without removing]' \
                        '--untrack[Remove from tracking only, keep packages]' \
                        '--all[Remove all packages including pre-existing]' \
                        '*:bundle:_vokun_bundle_names'
                    ;;
                select)
                    _vokun_bundle_names
                    ;;
                yeet)
                    _arguments \
                        '--untrack[Remove from bundle tracking only]'
                    ;;
                export)
                    _arguments \
                        '--json[Export in JSON format]' \
                        '--profile[Export specific profile]:profile:' \
                        '--all[Export all profiles]'
                    ;;
                cache)
                    _arguments \
                        '--clean[Keep last 2 versions of each package]' \
                        '--purge[Remove all cached packages]'
                    ;;
                size)
                    _arguments \
                        '--top[Show top N packages]:count:'
                    ;;
                recent)
                    _arguments \
                        '--count[Number of entries to show]:count:'
                    ;;
                import)
                    _arguments '--dry[Preview changes without applying]'
                    ;;
                hook)
                    local -a hook_cmds
                    hook_cmds=('install:Install the pacman hook' 'remove:Remove the pacman hook')
                    _describe -t hook-cmds 'hook subcommand' hook_cmds
                    ;;
                profile)
                    local -a profile_cmds
                    profile_cmds=(
                        'list:List all profiles'
                        'switch:Switch to a different profile'
                        'create:Create a new profile'
                        'delete:Delete a profile'
                        'copy:Copy bundles from one profile to another'
                        'show:Show the active profile'
                    )
                    _describe -t profile-cmds 'profile subcommand' profile_cmds
                    ;;
                find)
                    _arguments \
                        '--aur[Include AUR results]' \
                        '--pick[Interactively select packages to install]'
                    ;;
                which)
                    _arguments \
                        '--remote[Query remote repo/AUR info]'
                    ;;
                update)
                    _arguments \
                        '--aur[Include AUR packages]' \
                        '--aur-only[Update only AUR packages]' \
                        '--check[Show available upgrades without installing]'
                    ;;
                orphans)
                    _arguments \
                        '--clean[Remove all orphaned packages]' \
                        '--deep[Deep cleanup including AUR build deps]'
                    ;;
                list)
                    _arguments \
                        '--installed[Show only installed bundles]' \
                        '--deps[List packages installed as dependencies]'
                    ;;
                sync)
                    _arguments \
                        '--auto[Auto-reconcile without prompting]' \
                        '--quiet[Suppress informational output]'
                    ;;
                bundle)
                    _arguments \
                        '--editor[Open bundle TOML in $EDITOR directly]' \
                        '1:action:(create add rm edit delete)'
                    ;;
                log)
                    _arguments \
                        '--count[Number of entries to show]:count:'
                    ;;
                dotfiles)
                    local -a dotfiles_cmds
                    dotfiles_cmds=(
                        'init:Initialize dotfile tracking'
                        'apply:Apply dotfiles to the system'
                        'push:Push dotfile changes upstream'
                        'pull:Pull dotfile changes from upstream'
                        'status:Show dotfile tracking status'
                        'edit:Edit a tracked dotfile'
                    )
                    _describe -t dotfiles-cmds 'dotfiles subcommand' dotfiles_cmds
                    ;;
                snapshot)
                    _arguments \
                        '--dry-run[Preview without making changes]' \
                        '--yes[Skip confirmation prompts]' \
                        '1:action:(create list diff restore delete)'
                    ;;
                history)
                    _arguments \
                        '--installed[Show only installs]' \
                        '--removed[Show only removals]' \
                        '--upgraded[Show only upgrades]' \
                        '--downgraded[Show only downgrades]' \
                        '--search[Filter by package name]' \
                        '--count[Number of entries]:count:'
                    ;;
                help)
                    local -a help_topics
                    help_topics=(
                        'install' 'remove' 'select' 'list' 'info' 'search' 'status' 'get'
                        'yeet' 'find' 'which' 'owns' 'update' 'orphans'
                        'cache' 'size' 'recent' 'foreign' 'explicit'
                        'export' 'import' 'broken' 'hook' 'setup'
                        'uninstall' 'bundle' 'sync' 'check' 'diff'
                        'profile' 'log' 'rollback' 'dotfiles'
                        'why' 'snapshot' 'untracked' 'history' 'doctor' 'help'
                    )
                    _describe -t help-topics 'subcommand' help_topics
                    ;;
            esac
            ;;
    esac
}

_vokun "$@"
